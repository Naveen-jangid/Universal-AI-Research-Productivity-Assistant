# ─── Universal AI Research & Productivity Assistant ────────────────────────
# Copy this file to .env and fill in your values.
# Never commit your actual .env file to version control!

# ── OpenAI (Required for full functionality) ────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_CHAT_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_VISION_MODEL=gpt-4o
OPENAI_WHISPER_MODEL=whisper-1

# ── HuggingFace (Optional — used for local fallback models) ────────────────
HUGGINGFACE_API_TOKEN=hf_your_token_here
HF_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ── Web Search (Optional — for agent web search tool) ──────────────────────
# Get your key at: https://serpapi.com/
SERPAPI_API_KEY=your-serpapi-key-here

# ── Application ─────────────────────────────────────────────────────────────
APP_NAME=Universal AI Research & Productivity Assistant
APP_VERSION=1.0.0
DEBUG=false
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO

# ── Security ─────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-random-secret-in-production
ENABLE_API_KEY_AUTH=false

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:8501,http://127.0.0.1:8501

# ── Storage ──────────────────────────────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=50
FAISS_INDEX_PATH=vectorstore/faiss_index
SQLITE_DB_PATH=memory/assistant.db

# ── RAG ───────────────────────────────────────────────────────────────────────
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
TOP_K_RETRIEVAL=5

# ── Memory ────────────────────────────────────────────────────────────────────
MEMORY_WINDOW_SIZE=20
MAX_MEMORY_TOKENS=4000
